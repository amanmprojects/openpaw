{
  "name": "openpaw",
  "type": "module",
  "bin": {
    "openpaw": "./cli/openpaw.tsx"
  },
  "scripts": {
    "dev": "bun run --watch ./cli/openpaw.tsx tui",
    "gateway": "bun run ./cli/openpaw.tsx gateway start",
    "onboard": "bun run ./cli/openpaw.tsx onboard",
    "reset": "bun run ./cli/openpaw.tsx reset",
    "typecheck": "tsc --noEmit",
    "build": "bun build --compile --minify --target=bun-linux-x64 ./cli/openpaw.tsx --outfile openpaw"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.37",
    "@opentui/core": "^0.1.90",
    "@opentui/react": "^0.1.90",
    "ai": "^6.0.138",
    "commander": "^14.0.3",
    "grammy": "^1.41.1",
    "react": "^19.2.4",
    "telegram-markdown-v2": "^0.0.4",
    "web-tree-sitter": "0.25.10",
    "zod": "^4.3.6"
  }
}
