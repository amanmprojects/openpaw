{
  "name": "@amanm/openpaw",
  "version": "0.2.0",
  "description": "Local Bun + TypeScript agent runtime with TUI and messaging gateway adapters.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amanmprojects/openpaw.git"
  },
  "homepage": "https://github.com/amanmprojects/openpaw",
  "bugs": {
    "url": "https://github.com/amanmprojects/openpaw/issues"
  },
  "license": "MIT",
  "type": "module",
  "bin": {
    "openpaw": "bin/openpaw.cjs",
    "opaw": "bin/openpaw.cjs"
  },
  "scripts": {
    "openpaw": "bun run ./cli/openpaw.tsx",
    "gateway:dev": "bun run ./cli/openpaw.tsx gateway dev",
    "tui": "bun run ./cli/openpaw.tsx tui",
    "onboard": "bun run ./cli/openpaw.tsx onboard",
    "typecheck": "bunx tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "files": [
    "agent/",
    "bin/",
    "bundled-skills/",
    "cli/",
    "config/",
    "gateway/",
    "README.md",
    "AGENTS.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.37",
    "@opentui/core": "^0.1.90",
    "@opentui/react": "^0.1.90",
    "ai": "^6.0.138",
    "commander": "^14.0.3",
    "grammy": "^1.41.1",
    "react": "^19.2.4",
    "tg-markdown-converter": "^1.1.1",
    "web-tree-sitter": "0.25.10",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  }
}
